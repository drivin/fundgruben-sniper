# Standort-Slug fuer die IKEA Second-Hand-Seite
LOCATION=kassel

# Kommagetrennte Suchworte, case-insensitive und als Teiltreffer nutzbar
SEARCH_TERMS=bett,sofa,tisch

# Optional; leer lassen oder entfernen fuer den Standardwert 300
CHECK_INTERVAL_SECONDS=300

# Optional; false senkt CPU deutlich, sucht dann aber nicht auf Detailseiten
SCRAPE_PRODUCT_DETAILS=true

# Pflichtwerte fuer Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
