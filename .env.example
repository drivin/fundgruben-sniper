# Location slug for the IKEA Second-Hand page
LOCATION=kassel

# Comma-separated search terms, case-insensitive and matched as substrings
SEARCH_TERMS=bed,sofa,table

# Optional; leave empty or remove for the default value 300
CHECK_INTERVAL_SECONDS=300

# Optional; false significantly reduces CPU usage, but does not search detail pages
SCRAPE_PRODUCT_DETAILS=false

# Required Telegram values
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
